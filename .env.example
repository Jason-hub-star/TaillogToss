# Supabase (필수)
EXPO_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Backend (선택 — adb reverse 사용 시 기본값 127.0.0.1:8765)
# EXPO_PUBLIC_BACKEND_URL=http://127.0.0.1:8765

# Toss Ads SDK (사업자등록 후 Developers Console에서 발급)
# 미설정 시 테스트 ID(ait-ad-test-rewarded-id)로 fallback
# AIT_AD_R1=ait-ad-XXXXXXXX  # survey-result 보상형
# AIT_AD_R2=ait-ad-XXXXXXXX  # dashboard/analysis 보상형
# AIT_AD_R3=ait-ad-XXXXXXXX  # coaching-result 보상형

# AI 훈련데이터 텔레그램 검수 자동화 (선택)
TAILLOG_TELEGRAM_BOT_TOKEN=
TAILLOG_TELEGRAM_CHAT_ID=
TAILLOG_TELEGRAM_CALLBACK_SECRET=
ADMIN_API_KEY=
BACKEND_BASE_URL=http://localhost:8765
